<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <TargetFramework>net9.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="Alchyr.Sts2.BaseLib" Version="0.1.3" />
      <PackageReference Include="GodotSharp" Version="4.6.0-dev.5" />
      <PackageReference Include="Lib.Harmony" Version="2.4.2" />
      <AdditionalFiles Include="ActsFromThePast/localization/**/*.json"/>
    </ItemGroup>

    <ItemGroup>
      <Reference Include="sts2">
        <HintPath>..\..\..\..\..\Program Files (x86)\Steam\steamapps\common\Slay the Spire 2\data_sts2_windows_x86_64\sts2.dll</HintPath>
      </Reference>
    </ItemGroup>

    <Target Name="PostBuild" AfterTargets="PostBuildEvent">
      <Exec Command="copy /Y &quot;$(TargetPath)&quot; &quot;C:\Program Files (x86)\Steam\steamapps\common\Slay the Spire 2\mods\&quot;" />
      <Copy SourceFiles="ActsFromThePast.json" DestinationFolder="C:\Program Files (x86)\Steam\steamapps\common\Slay the Spire 2\mods\ActsFromThePast\"/>

    </Target>

</Project>
